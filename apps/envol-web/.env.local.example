# ── Envol Web — variables d'environnement ──────────────────────────────────

# URL de l'API backend (packages/api)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Clé API Duffel (server-side only — ne jamais préfixer NEXT_PUBLIC_)
# Obtenez votre clé sur https://app.duffel.com/
# Sans cette clé, le mode DÉMO avec données fictives est activé automatiquement.
DUFFEL_API_KEY=duffel_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (optionnel pour le front — l'API backend l'utilise)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
