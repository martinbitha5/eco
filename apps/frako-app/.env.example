# Frako App - Variables d'environnement
# Copier vers .env (à la racine du monorepo ou dans apps/frako-app)

EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_API_URL=http://localhost:4000

# Sur appareil physique : utiliser l'IP de ta machine (ex: http://192.168.1.10:4000)
# Sur émulateur Android : http://10.0.2.2:4000
