# Configuration SMTP pour l'envoi d'emails de confirmation
# Copiez ce fichier en .env.local et remplissez vos valeurs

# Gmail exemple: smtp.gmail.com | Outlook: smtp-mail.outlook.com | Mailtrap: sandbox.smtp.mailtrap.io
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false

# Votre adresse email et mot de passe d'application (Gmail: activer "App Password")
SMTP_USER=votre@email.com
SMTP_PASS=votre_mot_de_passe_app

# Adresse expéditeur affichée dans les emails
SMTP_FROM=noreply@frako.com

# URL publique de l'app (pour les liens dans les emails)
NEXT_PUBLIC_APP_URL=http://localhost:3002
