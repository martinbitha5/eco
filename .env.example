# ===========================================
# Écosystème RDC - Variables d'environnement
# ===========================================
# Copier vers .env et remplir les valeurs

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- API Core ---
API_URL=http://localhost:4000
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- ScoreCongo ---
SCORECONGO_CONSULTATION_LIMIT_FREE=3
SCORECONGO_CONSULTATION_PRICE_USD=2

# --- Frako ---
FRAKO_BNPL_MAX_INSTALLMENTS=6
FRAKO_APP_SCHEME=frako
FRAKO_APP_DEEPLINK_HOST=app.frako.cd

# --- Envol ---
DUFFEL_API_KEY=your-duffel-api-key
DUFFEL_API_URL=https://api.duffel.com

# --- Scoring Engine (Python) ---
SCORING_ENGINE_URL=http://localhost:5000
SCORING_ENGINE_API_KEY=your-scoring-engine-secret

# --- Jobs (cron) - Clé pour appeler POST /api/v1/frako/jobs/process-late-payments ---
JOB_API_KEY=your-secret-job-key

# --- Auth / OTP ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=
